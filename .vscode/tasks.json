{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build OpenCV",
            "type": "shell",
            "command": "C:/msys64/mingw64/bin/g++.exe",
            "args": [
                "img.cpp",
                "-o",
                "img.exe",
                "-IC:/msys64/mingw64/include/opencv4",
                "-LC:/msys64/mingw64/lib",
                "-lopencv_core",
                "-lopencv_imgproc",
                "-lopencv_imgcodecs",
                "-lopencv_highgui",
                "-lcomdlg32"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}